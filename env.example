# ════════════════════════════════════════════════════════════════
#  .env.example  ·  Renombra este archivo a  .env  y completa
# ════════════════════════════════════════════════════════════════

# ── Binance Futures ───────────────────────────────────────────
# Crea tus claves en: binance.com → Perfil → API Management
# Permisos necesarios: "Leer" + "Trading de Futuros"
# NUNCA actives "Retirar"
API_KEY=TU_API_KEY_AQUI
API_SECRET=TU_API_SECRET_AQUI

# ── Telegram (opcional pero muy recomendado) ──────────────────
# 1. Habla con @BotFather en Telegram → /newbot
# 2. Copia el token que te da
# 3. Habla con tu bot y luego visita:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    para obtener tu chat_id
TELEGRAM_TOKEN=TU_TOKEN_AQUI
TELEGRAM_CHAT_ID=TU_CHAT_ID_AQUI


# ════════════════════════════════════════════════════════════════
#  GUÍA DE INSTALACIÓN Y USO
# ════════════════════════════════════════════════════════════════
#
#  1. Instalar dependencias:
#     pip install -r requirements.txt
#
#  2. Copiar este archivo:
#     cp .env.example .env
#
#  3. Rellenar el .env con tus claves reales.
#
#  4. ANTES de usar con dinero real:
#     a) Cambia API_KEY/SECRET por claves de TESTNET de Binance Futures
#        (https://testnet.binancefuture.com)
#     b) Corre el bot al menos 2 semanas en paper trading
#     c) Revisa bot_xauusdt.log para verificar la lógica
#
#  5. Arrancar el bot:
#     python bot.py
#
#  6. Para detenerlo: Ctrl + C
#     El bot enviará una notificación de Telegram al cerrar.
#
# ════════════════════════════════════════════════════════════════
#  AJUSTES CLAVE EN bot.py (sección CONFIGURACIÓN CENTRAL)
# ════════════════════════════════════════════════════════════════
#
#  RISK_PCT      = 0.01   → Riesgo 1% por trade. NO subas esto.
#  MIN_RR        = 2.5    → R:R mínimo. NO bajes esto.
#  DAILY_LOSS_LIM= 0.03   → Bot se apaga al -3% diario.
#  SESSION_START = 13     → Hora GMT de inicio (Londres/NY)
#  SESSION_END   = 17     → Hora GMT de fin
#
#  Para agregar eventos de noticias manualmente (FOMC, NFP, etc.)
#  edita la lista NEWS_EVENTS en bot.py:
#
#  from datetime import datetime, timezone
#  NEWS_EVENTS = [
#      datetime(2025, 1, 29, 19, 0, tzinfo=timezone.utc),   # FOMC
#      datetime(2025, 2,  7, 13, 30, tzinfo=timezone.utc),  # NFP
#  ]
# ════════════════════════════════════════════════════════════════
